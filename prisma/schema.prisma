generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quotes    Quote[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  quotes    Quote[]
}

model Quote {
  id          String         @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  fileName    String
  fileType    String
  status      String         @default("pending")
  userId      String
  categoryId  String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id])
  category    Category       @relation(fields: [categoryId], references: [id])
  analysis    QuoteAnalysis?
}

model QuoteAnalysis {
  id                 String   @id @default(cuid())
  quoteId            String   @unique
  quote              Quote    @relation(fields: [quoteId], references: [id])
  rawExtraction      Json
  supplierName       String?
  totalAmount        Float?
  lineItems          Json
  redFlags           Json
  summary            String?
  estimatedTimeframe String?
  priceScore         Int?
  priceVerdict       String?
  priceExplanation   String?
  reputationScore       Int?
  reputationVerdict     String?
  reputationExplanation String?
  timeScore          Int?
  timeVerdict        String?
  timeExplanation    String?
  recommendation     String?
  overallSummary     String?
  createdAt          DateTime @default(now())
}