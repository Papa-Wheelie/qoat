generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  quotes    Quote[]
  comments  Comment[]
  votes     Vote[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  quotes    Quote[]
}

model Quote {
  id          String         @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  fileName    String
  fileType    String
  status      String         @default("pending")
  suburb      String?
  state       String?
  userId      String
  categoryId  String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id])
  category    Category       @relation(fields: [categoryId], references: [id])
  analysis    QuoteAnalysis?
  comments    Comment[]
  votes       Vote[]
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  quoteId   String
  userId    String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  quote     Quote     @relation(fields: [quoteId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  votes     Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  quoteId   String?
  commentId String?
  userId    String
  createdAt DateTime @default(now())
  quote     Quote?   @relation(fields: [quoteId], references: [id])
  comment   Comment? @relation(fields: [commentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, quoteId])
  @@unique([userId, commentId])
}

model QuoteAnalysis {
  id                 String   @id @default(cuid())
  quoteId            String   @unique
  quote              Quote    @relation(fields: [quoteId], references: [id])
  rawExtraction      Json
  supplierName       String?
  totalAmount        Float?
  lineItems          Json
  redFlags           Json
  questionsToAsk     Json?
  summary            String?
  publicSummary      String?
  estimatedTimeframe String?
  priceScore         Int?
  priceVerdict       String?
  priceExplanation   String?
  reputationScore       Int?
  reputationVerdict     String?
  reputationExplanation String?
  timeScore          Int?
  timeVerdict        String?
  timeExplanation    String?
  recommendation     String?
  overallSummary     String?
  createdAt          DateTime @default(now())
}