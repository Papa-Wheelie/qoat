generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String?
  password      String?
  emailVerified DateTime?
  role          String            @default("user")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  quotes        Quote[]
  comments      Comment[]
  votes         Vote[]
  accounts      Account[]
  reactions     CommentReaction[]
  helpfulMarks  HelpfulMark[]
  similarQuotes SimilarQuote[]
  reportsMade     Report[]        @relation("ReportsMade")
  reportsResolved Report[]        @relation("ReportsResolved")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  quotes    Quote[]
}

model TopCategory {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  subcategories Subcategory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Subcategory {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  topCategoryId String
  topCategory   TopCategory @relation(fields: [topCategoryId], references: [id])
  quotes        Quote[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Quote {
  id            String         @id @default(cuid())
  title         String
  description   String?
  fileUrl       String
  fileName      String
  fileType      String
  status              String         @default("pending")
  hidden              Boolean        @default(false)
  suburb              String?
  state               String?
  welcomeAcknowledged Boolean        @default(false)
  titleEdited         Boolean        @default(false)
  categoryEdited      Boolean        @default(false)
  locationEdited      Boolean        @default(false)
  analysisStatus          String         @default("pending")
  privateNickname         String?
  locationPromptDismissed Boolean        @default(false)
  userId        String
  categoryId    String
  subcategoryId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory?   @relation(fields: [subcategoryId], references: [id])
  analysis      QuoteAnalysis?
  comments      Comment[]
  votes         Vote[]
  helpfulMarks  HelpfulMark[]
  similarQuotes SimilarQuote[]
  reports       Report[]
}

model Comment {
  id        String            @id @default(cuid())
  content   String
  quoteId   String
  userId    String
  parentId  String?
  hidden    Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  quote     Quote             @relation(fields: [quoteId], references: [id])
  user      User              @relation(fields: [userId], references: [id])
  parent    Comment?          @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[]         @relation("CommentReplies")
  votes     Vote[]
  reactions CommentReaction[]
  reports   Report[]
}

model Vote {
  id        String   @id @default(cuid())
  quoteId   String?
  commentId String?
  userId    String
  value     Int      @default(1)
  createdAt DateTime @default(now())
  quote     Quote?   @relation(fields: [quoteId], references: [id])
  comment   Comment? @relation(fields: [commentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, quoteId])
  @@unique([userId, commentId])
}

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([commentId, userId, emoji])
}

model HelpfulMark {
  id        String   @id @default(cuid())
  quoteId   String
  userId    String
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([quoteId, userId])
}

model SimilarQuote {
  id        String   @id @default(cuid())
  quoteId   String
  userId    String
  price     Float?
  note      String?
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([quoteId, userId])
}

model Report {
  id           String    @id @default(cuid())
  reporterId   String
  reason       String
  details      String?
  status       String    @default("pending")
  quoteId      String?
  commentId    String?
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  reporter     User      @relation("ReportsMade", fields: [reporterId], references: [id])
  resolvedBy   User?     @relation("ReportsResolved", fields: [resolvedById], references: [id])
  quote        Quote?    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  comment      Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([reporterId, quoteId])
  @@unique([reporterId, commentId])
}

model QuoteAnalysis {
  id                 String   @id @default(cuid())
  quoteId            String   @unique
  quote              Quote    @relation(fields: [quoteId], references: [id])
  rawExtraction      Json
  supplierName       String?
  totalAmount        Float?
  lineItems          Json
  redFlags           Json
  questionsToAsk     Json?
  summary            String?
  publicSummary      String?
  estimatedTimeframe String?
  priceScore         Int?
  priceVerdict       String?
  priceExplanation   String?
  reputationScore       Int?
  reputationVerdict     String?
  reputationExplanation String?
  timeScore          Int?
  timeVerdict        String?
  timeExplanation    String?
  recommendation     String?
  overallSummary     String?
  googleRating          Float?
  googleReviewCount     Int?
  googlePlaceId         String?
  googleUrl             String?
  googleReviews         Json?
  googleMatchConfident  Boolean  @default(false)
  googleDiagnostics     Json?
  reputationSignals  Json?
  complianceFlags    Json?
  priceSampleSize    Int?
  methodologyVersion String?
  modelVersion       String?
  analysedAt         DateTime @default(now()) @updatedAt
  priceComparableIds String[] @default([])
  jobSize            Json?
  // embedding column is vector(1024) — managed via raw SQL (pgvector, Voyage AI voyage-3).
  // See scripts/setup-pgvector.ts. Cannot use in normal Prisma queries.
  embedding          Unsupported("vector(1024)")?
  createdAt          DateTime @default(now())
}